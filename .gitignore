# Dependencies
node_modules/

# Build outputs
dist/
out/
.next/
*.tsbuildinfo

# Runtime data
data/
*.db
*.db-shm
*.db-wal

# Env & secrets
.env
.env.*
!.env.example

# Logs
*.log

# Halo runtime — match nested .halo/ in monorepo subpackages too
**/.halo/secrets/
**/.halo/logs/
**/.halo/sessions/
**/.halo/memory/
**/.halo/agents/
**/.halo/skills/
**/.halo/canvas/
**/.halo/assets/
**/.halo/tmp/
**/.halo/evo/
**/.halo/workspace.json
**/.halo/halo.db
**/.halo/halo.db-shm
**/.halo/halo.db-wal
*.pid
*.lock

# Misdirected workspace dirs (happens when server cwd is wrong)
wsp_*/

# OS & editor
.DS_Store
Thumbs.db
.turbo
*.swp
*~
.vscode/
.idea/

# Claude Code local config (per-user settings + tools)
.claude/

# Test coverage
coverage/

# Backup
*.bak

# Desktop (Electron) build artifacts — all generated by `pnpm prepack-dmg` /
# `pnpm gen-icon` / `electron-builder`. Source for these lives under
# packages/desktop/scripts/ and src/. dist/ is already ignored above.
packages/desktop/resources/server-runtime/
packages/desktop/resources/cli-runtime/
packages/desktop/resources/admin-out/
packages/desktop/resources/node
packages/desktop/resources/node.exe
packages/desktop/resources/icon.icns
packages/desktop/resources/icon.ico
packages/desktop/resources/icon.png
packages/desktop/resources/Halo.iconset/
packages/desktop/resources/halo-version
# Local-only stage state: which target resources/ currently holds (drives
# `--fast` re-stage) + cached node binary archives (per-target subdirs).
packages/desktop/resources/.stage-meta
packages/desktop/.node-cache/

# Kept release artifacts — manually-curated good builds (dmg / exe) copied out
# of dist/ so re-packaging doesn't overwrite them. Large binaries, not tracked.
packages/desktop/dist-keep/

# CLI publish bundle — generated by `pnpm --filter @turmind/halo-cli bundle`
# from cli/server/core package.json + dist outputs. Not human-edited.
packages/cli/dist-pub/

# Local-only packaging notes — host setup + China-region distribution findings
# that shouldn't ship in git, but the committed desktop-packaging.md points here
# so a future packaging run reads it. Single explicit path (the docs/ tree is
# otherwise tracked).
.halo/docs/dev/desktop-packaging.local.md
