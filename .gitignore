# Dependencies
node_modules/

# Build outputs
dist/
out/
.next/
*.tsbuildinfo

# Monaco staged into public/ by copy-monaco.mjs --dev (next dev serves it at /monaco/vs)
packages/admin/public/monaco/

# Runtime data
data/
*.db
*.db-shm
*.db-wal

# Env & secrets
.env
.env.*
!.env.example

# Logs
*.log

# Halo runtime — match nested .halo/ in monorepo subpackages too
**/.halo/secrets/
**/.halo/logs/
**/.halo/sessions/
**/.halo/memory/
**/.halo/agents/
# …but the workspace root's agent configs are shared project config — track them
!/.halo/agents/
**/.halo/skills/
**/.halo/canvas/
**/.halo/assets/
**/.halo/tmp/
**/.halo/evo/
**/.halo/USER.md
**/.halo/workspace.json
**/.halo/halo.db
**/.halo/halo.db-shm
**/.halo/halo.db-wal
*.pid
*.lock

# Misdirected workspace dirs (happens when server cwd is wrong)
wsp_*/

# OS & editor
.DS_Store
Thumbs.db
.turbo
*.swp
*~
.vscode/
.idea/

# Claude Code local config (per-user settings + tools)
.claude/

# Test coverage
coverage/

# Backup
*.bak

# Desktop (Electron) build artifacts — all generated by `pnpm prepack-dmg` /
# `pnpm gen-icon` / `electron-builder`. Source for these lives under
# packages/desktop/scripts/ and src/. dist/ is already ignored above.
packages/desktop/resources/server-runtime/
packages/desktop/resources/cli-runtime/
packages/desktop/resources/admin-out/
packages/desktop/resources/node
packages/desktop/resources/node.exe
packages/desktop/resources/icon.icns
packages/desktop/resources/icon.ico
packages/desktop/resources/icon.png
packages/desktop/resources/Halo.iconset/
packages/desktop/resources/halo-version
# Local-only stage state: which target resources/ currently holds (drives
# `--fast` re-stage) + cached node binary archives (per-target subdirs).
packages/desktop/resources/.stage-meta
packages/desktop/.node-cache/

# Kept release artifacts — manually-curated good builds (dmg / exe) copied out
# of dist/ so re-packaging doesn't overwrite them. Large binaries, not tracked.
packages/desktop/dist-keep/

# CLI publish bundle — generated by `pnpm --filter @turmind/halo-cli bundle`
# from cli/server/core package.json + dist outputs. Not human-edited.
packages/cli/dist-pub/

# Local-only docs — host-specific deployment details (HOME paths, systemd
# units, CloudFront ids, tokens) that shouldn't ship in git. Explicit paths
# (the docs/ tree is otherwise tracked).
.halo/docs/dev/desktop-packaging.local.md
.halo/docs/dev/dev-environment.local.md

# Internal WIP — proposals/drafts and test cases. Kept local (the team uses
# them) but not published to the public repo or the npm bundle; they leak
# stale info and read as noise to anyone browsing the source.
.halo/docs/plans/
.halo/docs/test/

# Local-only scratch — one-off review changelogs and the repo-root tmp/ work
# dir (migration scripts, verify checklists). Not shipped.
/tmp/
halo-changelog-*.md
# AgentCore demo: pnpm-deploy output baked into the Docker image (238MB)
packages/agentcore-demo/deploy/

# CDK synth output + context cache (context caches account id / AZs)
cdk.out/
cdk.context.json

# halo-city .musictest.mjs screenshot output (lands in whatever cwd ran it)
.musictest.png
