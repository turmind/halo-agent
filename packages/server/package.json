{
  "name": "@turmind/halo-server",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./agents/*": "./dist/agents/*.js",
    "./config": "./dist/config.js",
    "./init": "./dist/init.js",
    "./db/*": "./dist/db/*.js",
    "./sessions/*": "./dist/sessions/*.js",
    "./tools/*": "./dist/tools/*.js",
    "./prompts/*": "./dist/prompts/*.js",
    "./channels/shared/*": "./dist/channels/shared/*.js",
    "./commands/*": "./dist/commands/*.js",
    "./middleware/*": "./dist/middleware/*.js",
    "./setup-config": "./dist/setup-config.js",
    "./setup-settings": "./dist/setup-settings.js",
    "./setup-providers": "./dist/setup-providers.js",
    "./logger": "./dist/logger.js"
  },
  "typesVersions": {
    "*": {
      "agents/*": [
        "./dist/agents/*"
      ],
      "config": [
        "./dist/config"
      ],
      "init": [
        "./dist/init"
      ],
      "db/*": [
        "./dist/db/*"
      ],
      "sessions/*": [
        "./dist/sessions/*"
      ],
      "tools/*": [
        "./dist/tools/*"
      ],
      "prompts/*": [
        "./dist/prompts/*"
      ],
      "channels/shared/*": [
        "./dist/channels/shared/*"
      ],
      "commands/*": [
        "./dist/commands/*"
      ],
      "middleware/*": [
        "./dist/middleware/*"
      ],
      "setup-config": [
        "./dist/setup-config"
      ],
      "setup-settings": [
        "./dist/setup-settings"
      ],
      "setup-providers": [
        "./dist/setup-providers"
      ],
      "logger": [
        "./dist/logger"
      ]
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1030.0",
    "@aws-sdk/credential-provider-node": "^3.972.30",
    "@turmind/halo-core": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "@larksuiteoapi/node-sdk": "^1.65.0",
    "@parcel/watcher": "^2.5.6",
    "@smithy/signature-v4": "^5.3.13",
    "better-sqlite3": "^11.7.0",
    "chokidar": "^5.0.0",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.42.0",
    "hono": "^4.6.0",
    "nanoid": "^5.0.9",
    "node-pty": "1.2.0-beta.12",
    "qrcode": "^1.5.4",
    "ws": "^8.18.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.5.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
